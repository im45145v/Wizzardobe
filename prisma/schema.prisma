generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wardrobeItems    WardrobeItem[]
  outfits          Outfit[]
  locationProfiles LocationProfile[]
  calendarEvents   CalendarEvent[]

  @@index([email])
}

model WardrobeItem {
  id             String   @id @default(cuid())
  userId         String
  name           String
  category       String
  dominantColor  String
  tags           String[] @default([])
  season         String
  formalityScore Int
  timesWorn      Int      @default(0)
  lastWornAt     DateTime?
  locationTag    String
  isActive       Boolean  @default(true)
  imageUrl       String?
  costPrice      Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitItems OutfitItem[]
  usageLogs  UsageLog[]

  @@index([userId])
  @@index([isActive])
  @@index([lastWornAt])
  @@index([userId, isActive])
  @@index([userId, category, isActive])
  @@index([userId, locationTag, isActive])
}

model Outfit {
  id                   String   @id @default(cuid())
  userId               String
  generatedBy          String
  aestheticScore       Float?
  confidencePrediction Float?
  isAccepted           Boolean  @default(false)
  isScheduled          Boolean  @default(false)
  scheduledFor         DateTime?
  reasoning            String?
  createdAt            DateTime @default(now())

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      OutfitItem[]
  usageLogs  UsageLog[]
  ratingLogs RatingLog[]

  @@index([userId])
  @@index([userId, isScheduled])
  @@index([scheduledFor])
}

model OutfitItem {
  id             String @id @default(cuid())
  outfitId       String
  wardrobeItemId String

  outfit       Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  wardrobeItem WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: Cascade)

  @@unique([outfitId, wardrobeItemId])
  @@index([outfitId])
  @@index([wardrobeItemId])
}

model UsageLog {
  id       String   @id @default(cuid())
  itemId   String
  outfitId String?
  wornAt   DateTime @default(now())

  item   WardrobeItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  outfit Outfit?      @relation(fields: [outfitId], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([outfitId])
  @@index([wornAt])
}

model RatingLog {
  id               String   @id @default(cuid())
  outfitId         String
  rating           Int
  confidenceRating Int
  notes            String?
  createdAt        DateTime @default(now())

  outfit Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)

  @@index([outfitId])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  eventType   String?
  formality   Int?
  externalId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, startTime])
  @@index([externalId])
}

model LocationProfile {
  id       String  @id @default(cuid())
  userId   String
  name     String
  isActive Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}
